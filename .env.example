# ============================================================
# Sk6.0 — Environment Variables
# Copy to .env and fill all values before starting.
# Never commit .env to git.
# ============================================================

# ── Database ───────────────────────────────────────────────
DB_PASSWORD=change_this_strong_password

# ── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=change_this_strong_password

# ── Application ────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_64_char_hex_secret

# ── Domain & TLS ───────────────────────────────────────────
DOMAIN=sk6.yourdomain.com

# ── Monitoring ─────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_this_strong_password

# ── Object Storage (RustFS) ────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(20))"
RUSTFS_ACCESS_KEY=change_this_access_key
RUSTFS_SECRET_KEY=change_this_secret_key
RUSTFS_BUCKET=sk6-static
RUSTFS_BACKUP_BUCKET=sk6-backups

# ── Celery Flower ──────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=change_this_strong_password

# ── Deployment ─────────────────────────────────────────────
IMAGE_TAG=latest
