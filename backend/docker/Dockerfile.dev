# ============================================================
# Sk6.0 Backend — Development Dockerfile
# Hot-reload via uvicorn --reload + watchmedo for Celery.
# Includes debugpy for remote debugging from VSCode/PyCharm.
# ============================================================

FROM python:3.12-slim

WORKDIR /app

# Dev OS tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    libpq5 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install ALL deps including dev (pytest, mypy, watchdog, debugpy)
COPY requirements.txt requirements-dev.txt ./
RUN pip install --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt -r requirements-dev.txt

# watchmedo is part of watchdog — needed for Celery auto-reload in dev
RUN pip install --no-cache-dir watchdog[watchmedo]

# debugpy for remote debugging (listens on 5678)
RUN pip install --no-cache-dir debugpy

EXPOSE 8000 5678

# Source code mounted as a volume in docker-compose.dev.yml
# so no COPY here — changes reflect immediately on --reload
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
