# ============================================================
# Sk6.0 — Alertmanager Configuration
# Copy to alertmanager.yml and fill in real values.
# alertmanager.yml is gitignored — never commit real tokens.
# ============================================================

global:
  resolve_timeout: 5m

route:
  receiver: telegram-critical
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  group_by: [alertname, severity]
  routes:
    - match:
        severity: critical
      receiver: telegram-critical
      repeat_interval: 15m
    - match:
        severity: page
      receiver: telegram-critical
      repeat_interval: 1h
    - match:
        severity: warn
      receiver: telegram-warn
      repeat_interval: 6h

receivers:
  - name: telegram-critical
    telegram_configs:
      - bot_token: 'REPLACE_WITH_BOT_TOKEN'
        chat_id: REPLACE_WITH_CHAT_ID
        parse_mode: HTML
        send_resolved: true
        message: |
          {{ if eq .Status "firing" }}🚨{{ else }}✅{{ end }} <b>{{ .GroupLabels.alertname }}</b>
          Severity: <b>{{ .CommonLabels.severity }}</b>
          {{ range .Alerts }}• {{ .Annotations.summary }}
          {{ if .Annotations.description }}  {{ .Annotations.description }}{{ end }}
          {{ end }}

  - name: telegram-warn
    telegram_configs:
      - bot_token: 'REPLACE_WITH_BOT_TOKEN'
        chat_id: REPLACE_WITH_CHAT_ID
        parse_mode: HTML
        send_resolved: true
        message: |
          {{ if eq .Status "firing" }}⚠️{{ else }}✅{{ end }} <b>{{ .GroupLabels.alertname }}</b>
          {{ range .Alerts }}• {{ .Annotations.summary }}{{ end }}

inhibit_rules:
  - source_match:
      severity: critical
    target_match:
      severity: warn
    equal: [alertname, instance]
