# Dev config — no TLS, direct proxy to single API replica
upstream sk6_api_dev {
    server api-1:8000;
}

server {
    listen 80;
    client_max_body_size 10m;

    location /api/ {
        proxy_pass http://sk6_api_dev;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_http_version 1.1;
    }

    location /static/ {
        alias /app/static/;
    }

    location = /health {
        proxy_pass http://sk6_api_dev/health;
        access_log off;
    }
}
